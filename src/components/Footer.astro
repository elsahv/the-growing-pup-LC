---
import NavItems from "./NavItems.astro";

const today = new Date();
---

<footer
  id="footer"
  class="text- bg- border-t border-r rounded-tr-sm border-black pr-1 md:opacity-60 opacity-100 mt-5 pt-5"
>
  <div class="flex justify-center">
    <NavItems />
  </div>
  <p class="md:text-md text-sm">
    &copy; {today.getFullYear()}
  </p>
</footer>
