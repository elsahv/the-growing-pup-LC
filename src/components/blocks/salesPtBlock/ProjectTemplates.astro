---
const growingPup = {
  title: "The Growing Pup",
  subtitle: "Start simple. Look legit.",
  price: "$1,200",
  features: [
    "1-page website",
    "Mobile optimized",
    "Fast + SEO-ready",
    "Contact section or form",
    "Social links integration",
    "Clean, modern design",
  ],
};

const risingCarnivore = {
  title: "The Rising Carnivore",
  subtitle: "Built to grow with you.",
  price: "$2,800",
  features: [
    "Up to 5 pages",
    "Strong brand + layout system",
    "Conversion-focused structure",
    "Blog / CMS ready",
    "Reusable, scalable components",
    "Performance-optimized build",
  ],
};
---

<div id="pricing-section" class="">
  <div id="pricing-container" class="mx-auto max-w-7xl">
    <!-- Header -->

    <!-- ?unsure if keeping v -->
    <!-- <div id="pricing-header" class="bg-test1 mb-12 text-center">
      <p
        id="pricing-label"
        class="mb-4 text-[11px] font-semibold uppercase tracking-[0.28em] text-neutral-700"
      >
        Pricing
      </p>

      <h2
        id="pricing-title"
        class="text-5xl font-semibold leading-[0.95] tracking-tight"
      >
        Simple sites for
      </h2>

      <p
        id="pricing-subtitle"
        class="mt-2 font-serif text-4xl italic leading-none text- md:text-6xl lg:text-7xl"
      >
        getting started &amp; growing
      </p>
    </div> -->
    <!-- ?unsure if keeping ^^^ -->

    <!-- Cards -->
    <div
      id="project-template-cards"
      class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]"
    >
      <!-- Growing Pup -->
      <article
        id="growing-pup-card"
        class="mt-5 mb-5 relative overflow-hidden rounded-md bg-papaya border border-onyx 2xl:p-10 p-4 shadow-[0_20px_45px_rgba(0,0,0,0.07)]"
      >
        <div
          id="growing-pup-badge"
          class="absolute left-5 top-5 z-10 inline-flex -rotate-6 rounded-full bg-[#f4bf17] px-4 py-2 text-sm font-semibold text- shadow-sm"
        >
          Start Here
        </div>

        <!-- Image Area -->
        <div
          id="growing-pup-image-wrapper"
          class="relative mb-8 min-h-[250px] md:min-h-[300px] bg-"
        >
          <img
            src="https://dl.dropboxusercontent.com/scl/fi/xzfhk2jletg2hqwc9ecks/coyote.png?rlkey=xtfjf7plvgb8y3fjxdij0vdt5&st=run4yzui&dl=0"
            alt=""
            width="1545px"
            height="1545px"
            class="-scale-x-100"
          />
        </div>

        <div id="growing-pup-content" class="relative z-10">
          <h3
            id="growing-pup-title"
            class="text-3xl font-semibold tracking-tight text- md:text-5xl"
          >
            {growingPup.title}
          </h3>

          <p
            id="growing-pup-subtitle"
            class="mt-2 font-serif text-2xl italic text-neutral-600 md:text-3xl"
          >
            {growingPup.subtitle}
          </p>

          <div
            id="growing-pup-price"
            class="mt-5 inline-flex rounded-full bg-[#e8e1e3] px-4 py-2 text-base text-"
          >
            Starting at <span class="ml-1 font-semibold"
              >{growingPup.price}</span
            >
          </div>

          <div
            id="growing-pup-features-section"
            class="bg- mt-6 border-t border-dashed border-neutral-400 pt-6"
          >
            <p
              id="growing-pup-features-label"
              class="mb-5 text-sm font-bold uppercase tracking-[0.16em] text-neutral-700"
            >
              What’s Included
            </p>

            <ul
              id="growing-pup-features-list"
              class="grid gap-x-8 gap-y-4 2xl:grid-cols-2"
            >
              {
                growingPup.features.map((item) => (
                  <li class="flex items-start gap-3 text-lg text- ">
                    <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-neutral-800 text-sm">
                      ✓
                    </span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>

            <a
              id="growing-pup-cta"
              href="#contact"
              class="mt-8 inline-flex items-center gap-3 rounded-full bg-carribean px-5 py-3 text-base font-medium text-papaya transition hover:opacity-90"
            >
              <span class="inline-flex h-4 w-4 rounded-full bg-[#f4bf17]"
              ></span>
              Get Started
            </a>
          </div>
        </div>
      </article>

      <!-- Rising Carnivore -->
      <article
        id="rising-carnivore-card"
        class="relative overflow-hidden rounded-lg border border-black bg-carribean 2xl:p-10 p-4 text-papaya shadow-[0_24px_50px_rgba(0,0,0,0.18)]"
      >
        <div id="rising-carnivore-content" class="mb-8">
          <h3
            id="rising-carnivore-title"
            class="text-3xl font-semibold tracking-tight md:text-5xl"
          >
            {risingCarnivore.title}
          </h3>

          <p
            id="rising-carnivore-subtitle"
            class="mt-2 font-serif text-2xl italic text-neutral-300 md:text-3xl"
          >
            {risingCarnivore.subtitle}
          </p>

          <div
            id="rising-carnivore-price"
            class="mt-5 inline-flex rounded-full border border-papaya/20 px-4 py-2 text-base text-papaya/90"
          >
            Starting at <span class="ml-1 font-semibold text-papaya"
              >{risingCarnivore.price}</span
            >
          </div>
        </div>

        <div
          id="rising-carnivore-features-section"
          class="border-t border-dashed border-papaya/30 pt-6"
        >
          <p
            id="rising-carnivore-features-label"
            class="mb-5 text-sm font-bold uppercase tracking-[0.16em] text-neutral-300"
          >
            What’s Included
          </p>

          <ul
            id="rising-carnivore-features-list"
            class="grid gap-x-8 gap-y-4 2xl:grid-cols-2"
          >
            {
              risingCarnivore.features.map((item) => (
                <li class="flex items-start gap-3 text-lg text-papaya">
                  <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-papaya/60 text-sm">
                    ✓
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>

          <a
            id="rising-carnivore-cta"
            href="#contact"
            class="mt-10 inline-flex items-center gap-4 rounded-2xl bg-papaya/10 px-5 py-4 text-lg font-medium text-papaya backdrop-blur transition hover:bg-papaya/15"
          >
            <span
              class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#ff6a00] text-"
            >
              ⌣
            </span>
            Build My Site
          </a>
        </div>

        <div
          id="rising-carnivore-decor"
          class="absolute -bottom-10 -right-10 h-44 w-44 rounded-full bg-[#ffb000]"
        >
        </div>
      </article>
    </div>

    <!-- Bottom Info -->
    <div id="pricing-footer" class="mt-8 grid gap-6 md:grid-cols-2">
      <div
        id="pause-card"
        class="rounded-[1.75rem] border border-[#d9d1d3] p-8"
      >
        <h4 class="text-2xl font-semibold text-">Pause anytime</h4>
        <p class="mt-3 text-lg text-neutral-600">
          Temporarily pause your project whenever you need.
        </p>
      </div>

      <div
        id="upgrade-card"
        class="rounded-[1.75rem] border border-[#d9d1d3] p-8"
      >
        <h4 class="text-2xl font-semibold text-">Upgrade when ready</h4>
        <p class="mt-3 text-lg text-neutral-600">
          Start small and grow when your business is ready.
        </p>
      </div>
    </div>
  </div>
</div>
