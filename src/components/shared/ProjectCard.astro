---
const frontmatter = Astro.props;
const { creativeProjectTitle, creativeProjectMainImg, alt, url } = frontmatter;
---

<div id="sq" class="opacity-70 hover:opacity-100 px-5 mt-5 pt-3">
  <a
    href={url}
    class="group relative block aspect-[4/3] overflow-hidden bg-neutral-800"
  >
    <!-- <div>{websiteNumber}.</div> -->
    <h2
      class="ml-3 text-3xl absolute inset-0 flex translate-y-4 flex-col items-center justify-center px-6 text-center opacity-0 transition duration-500 group-hover:translate-y-0 group-hover:opacity-100 z-50"
    >
      {creativeProjectTitle}
    </h2>
    <img
      src={creativeProjectMainImg}
      class="drop-shadow-xl rounded border-2 border-black my-1"
      alt={alt}
      class="h-full w-full object-cover transition duration-700 ease-out group-hover:scale-110 group-hover:opacity-40 z-0"
    />

    <div
      class="absolute inset-0 bg-black/0 transition duration-500 group-hover:bg-black/50"
    >
      <div
        id="post-excerpt"
        class="bg- text- black bg- mb-5 pb-3 drop-shadow-md"
      >
        <div class="pl-3 ml-1">
          <!-- <p class="opacity-80 text-lg">{testItem1}</p> -->
          <!-- <button class="text-primaryBtn underline opacity-70 hover:opacity-100"
          >read more...</button
        > -->
        </div>
      </div>
    </div>
  </a>
</div>
