---
interface Item {
  title: string;
  body: string;
  href?: string;
  linkLabel?: string;
}

interface Props {
  items: Item[];
  columns?: 2 | 3 | 4;
  minWidth?: number;
  className?: string;
  cardClassName?: string;
}

const {
  items = [],
  columns,
  minWidth = 220,
  className = "",
  cardClassName = "",
} = Astro.props;

const gridCols =
  columns === 2
    ? "grid-cols-1 md:grid-cols-2"
    : columns === 3
      ? "grid-cols-1 md:grid-cols-3"
      : columns === 4
        ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4"
        : "";

const autoFitStyle = !columns
  ? `grid-template-columns: repeat(auto-fit, minmax(${minWidth}px, 1fr));`
  : "";
---

<section class:list={["grid gap-6", gridCols, className]} style={autoFitStyle}>
  {
    items.map((item) => (
      <article
        class:list={[
          "flex min-h-[220px] flex-col justify-between border border-black/15 bg-teal-70 p-5 text-stone-",
          cardClassName,
        ]}
      >
        <div>
          <h3 class="mb-3  font-semibold leading-tight text-lg">
            {item.title}
          </h3>

          <p class="text-md leading-relaxed">{item.body}</p>
        </div>

        {item.href && (
          <a
            href={item.href}
            class="mt-4 inline-block text-sm underline underline-offset-2"
          >
            {item.linkLabel || "Learn more"}
          </a>
        )}
      </article>
    ))
  }
</section>
