---
// src/components/ClientSuccessStories.astro

const stories = [
  {
    title: "How LC helped this website",
    image: "/images/scotts-bass-lessons.jpg",
    name: "The Running Quail",
    tags: "UI design, design system, conversion optimisation",
    url: "https://therunningquail.com",
  },
  {
    title: "How LC helped this website",
    image: "/images/the-lost-estate.jpg",
    name: "HoveyRoofing",
    tags: "Highly themeable system, conversion optimisation, brand refinement",
    url: "https://hoveyroofing.com",
  },
  {
    title: "How LC helped this website",
    image: "/images/oceg.jpg",
    name: "EH-portfolio",
    tags: "Design system, marketing site redesign, asset creation",
    url: "https://elsahovey.com",
  },
  // {
  //   title: "How LC helped this website ",
  //   image: "/images/example-four.jpg",
  //   name: "The Indoor Jungle Project",
  //   tags: "Web design, development, content strategy",
  //   url: "https://theindoorjungleproject.com",
  // },
];
---

<section
  class="flex justify-end border-y-2 border-black bg-websiteFocus text-complimentryTextColor py-16"
>
  <div class="px-6 md:px-12">
    <p class="mb-12 text-sm font-bold uppercase tracking-wide">
      Selected Client Success Stories
    </p>

    <div class="horizontal-scroll overflow-x-auto pb-8">
      <div class="grid 2xl:grid-cols-3 grid-cols-2 min-w-max">
        {
          stories.map((story) => (
            <article
              id="sq"
              class="w-[82vw] max-w-[560px] shrink-0 border-r border-gray-500 px-8 first:pl-0 md:w-[520px] lg:w-[620px]"
            >
              <a href={story.url}>
                <h3 class="mb-4 max-w-full text-2xl font-semibold leading-[1.05] tracking-[-0.04em] md:text-3xl">
                  {story.title}
                </h3>

                <img
                  src="https://images.pexels.com/photos/13993601/pexels-photo-13993601.jpeg?_gl=1*1qo3u4r*_ga*MTA5MDE3MzI2MS4xNzU4MjUwMDM4*_ga_8JE65Q40S6*czE3Nzc5NTM4MjAkbzYyJGcxJHQxNzc3OTUzODI1JGo1NSRsMCRoMA.."
                  alt={story.name}
                  class="border-2 border-black mb-6 aspect-[1.1/1] w-full rounded-xl object-cover"
                />

                <h4 class="text-lg font-bold uppercase tracking-wide">
                  {story.name}
                </h4>

                <p class="mt-2 text-sm leading-snug text-neutralBase2">
                  {story.tags}
                </p>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
