---
import MainLayout from "./MainLayout.astro";
const { frontmatter } = Astro.props;
---

<MainLayout>
  <div
    id="teal-creativeProject-banner"
    class="bg-websiteFocus text-complimentryTextColor border-y-2 border-black flex justify-center pb-5 mb-5"
  >
    <div id="" class="w-3/4 mt-5 pt-5 text-lg p-">
      <div class="flex">
        <div class="my-5 p-5 font-semibold opacity-80 text- black">
          <h2 id="creativeProject-title" class="text-6xl">
            {frontmatter.creativeProjectTitle}
          </h2>
          <p id="creativeProject-description" class="opacity-80 text-lg mt-5">
            {frontmatter.creativeProjectDesc}
          </p>
        </div>

        <div id="creativeProject-mainImgcontainer" class="flex justify-end">
          <img
            id="main-img"
            src={frontmatter.creativeProjectMainImg.url}
            alt={frontmatter.creativeProjectMainImg.alt}
            class="my-5 border-2 border-black rounded-sm"
          />
        </div>
      </div>
    </div>
  </div>

  <div id="wrapper" class="flex justify-center pt-5 mt-5">
    <div id="container" class="mt-5 pt-5 w-3/4 max-w-7xl">
      <div id="grid" class="grid grid-cols-3 gap-5">
        <div id="sq1" class="bg- col-span-1">
          <img
            id="mini-img-screenshot"
            src={frontmatter.asidePhoto.url}
            alt={frontmatter.asidePhoto.alt}
            class="h- border-black border-r mt-5 sq-styles bg-test1"
          />
        </div>
        <div id="sq2" class="bg- col-span-2">
          <div class="text-websiteFocus mb-5 p-5 flex flex-col gap-y-5">
            <h2 id="about-title" class="text-4xl font-semibold">About</h2>
            <p id="about-content1" class="bg-test1">
              where the signature style meets real-world client strategy.{
                frontmatter.aboutProject
              }
            </p>
            <h2 class="text-4xl font-semibold">Scope of Work</h2>
            <p id="about-content2" class="bg-test1">
              {frontmatter.scopeOfWork}
            </p>
            <!-- TODO: CHANGE TO SMALL GALLERY IMG COMP -->

            <img
              id="coolors-img"
              src={frontmatter.coolorsImg.url}
              alt={frontmatter.coolorsImg.alt}
              class="sq-styles bg-test2"
            />

            <br />
            <button
              id="about-content4"
              class="sq-styles w-[130px] bg-primaryBtn text-complimentryTextColor"
            >
              <a href={frontmatter.callToAction}> view live site </a>
            </button>
          </div>

          <div class="mt-1 ml-1 mb-[55px] bg-">
            <!-- TODO: Lean Into Your Desert Identity (Signature Niche) V-->
            <!--  * 🔥 Strong Positioning Tagline Styles, Clear + Confident (Best for freelance clients) These are simple and effective. -->
            <!-- ? POTENTIAL TAGLINESv-->
