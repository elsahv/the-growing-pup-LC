          </div>
        </div>
      </div>
    </div>
  </div>
  <div
    id="creative-project-slot-wrapper"
    class="text-websiteFocus flex justify-end"
  >
    <div
      id="creative-project-slot-container"
      class="bg- w-2/3 pl-[120px] pr-[250px]"
    >
      <slot />
    </div>
  </div>
</MainLayout>
