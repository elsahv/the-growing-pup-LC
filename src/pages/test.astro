---
interface Props {
  imageSrc?: string;
  imageAlt?: string;
  repLabel?: string;
  companyName?: string;
  contactName?: string;
  contactEmail?: string;
  contactPhone?: string;
}

const {
  imageSrc = "/eh-img.jpg",
  imageAlt = "Contact photo",
  repLabel = "Representation",
  companyName = "Spacestation Management",
  contactName = "Sean Holladay",
  contactEmail = "Holladay@spacestation.com",
  contactPhone = "928-242-4534",
} = Astro.props;
---

<section class="bg-stone-100 px-6 py-10 md:px-10 lg:px-12">
  <div class="mx-auto max-w-7xl">
    <h2 class="mb-8 font-serif text-3xl font-semibold tracking-wide text-black">
      Contact
    </h2>

    <div class="grid gap-8 lg:grid-cols-[1.05fr_1.1fr] lg:items-start">
      <div>
        <img src={imageSrc} alt={imageAlt} class="-1/2" />
      </div>

      <div class="flex flex-col gap-8">
        <div
          class="grid gap-8 border-b border-black/15 pb-8 md:grid-cols-[1.2fr_1fr]"
        >
          <div>
            <p class="mb-4 font-serif text-lg font-semibold text-black">
              {repLabel}
            </p>
            <h3
              class="max-w-[14rem] font-serif text-4xl font-semibold leading-none text-black md:text-5xl"
            >
              {companyName}
            </h3>
          </div>

          <div class="space-y-6 font-serif text-lg font-semibold text-black">
            <p>{contactName}</p>
            <p>
              <a href={`mailto:${contactEmail}`} class="hover:underline">
                {contactEmail}
              </a>
            </p>
            <p>
              <a
                href={`tel:${contactPhone.replace(/[^\d+]/g, "")}`}
                class="hover:underline"
              >
                {contactPhone}
              </a>
            </p>
          </div>
        </div>

        <form class="space-y-6">
          <fieldset class="space-y-3">
            <legend class="mb-3 font-serif text-xl font-semibold text-black">
              Purpose of email <span class="text-base font-normal text-black/70"
                >(required)</span
              >
            </legend>

            <label
              class="flex items-center gap-3 font-serif text-lg text-black"
            >
              <input
                type="radio"
                name="purpose"
                value="business-inquiries"
                class="h-5 w-5 border border-black text-black focus:ring-black"
                required
              />
              <span>Business Inquiries</span>
            </label>

            <label
              class="flex items-center gap-3 font-serif text-lg text-black"
            >
              <input
                type="radio"
                name="purpose"
                value="booking-schedule"
                class="h-5 w-5 border border-black text-black focus:ring-black"
                required
              />
              <span>Booking &amp; Schedule</span>
            </label>
          </fieldset>

          <div>
            <p class="mb-2 font-serif text-xl font-semibold text-black">Name</p>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label
                  for="firstName"
                  class="mb-1 block font-serif text-base font-semibold text-black"
                >
                  First Name <span class="font-normal text-black/70"
                    >(required)</span
                  >
                </label>
                <input
                  id="firstName"
                  name="firstName"
                  type="text"
                  required
                  class="w-full border border-black/15 bg-transparent px-4 py-3 outline-none transition focus:border-black"
                />
              </div>

              <div>
                <label
                  for="lastName"
                  class="mb-1 block font-serif text-base font-semibold text-black"
                >
                  Last Name <span class="font-normal text-black/70"
                    >(required)</span
                  >
                </label>
                <input
                  id="lastName"
                  name="lastName"
                  type="text"
                  required
                  class="w-full border border-black/15 bg-transparent px-4 py-3 outline-none transition focus:border-black"
                />
              </div>
            </div>
          </div>

          <div>
            <label
              for="email"
              class="mb-1 block font-serif text-xl font-semibold text-black"
            >
              Email <span class="text-base font-normal text-black/70"
                >(required)</span
              >
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full border border-black/15 bg-transparent px-4 py-3 outline-none transition focus:border-black"
            />
          </div>

          <div>
            <label
              for="message"
              class="mb-1 block font-serif text-xl font-semibold text-black"
            >
              Message (All Spam Will Be Ignored)
              <span class="text-base font-normal text-black/70">
                (required)</span
              >
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full resize-none border border-black/15 bg-transparent px-4 py-3 outline-none transition focus:border-black"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-black px-6 py-4 text-center font-serif text-xl font-semibold uppercase tracking-[0.12em] text-white transition hover:opacity-90"
          >
            Submit
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
