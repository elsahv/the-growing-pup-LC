---
import DynamicGrid from "../components/shared/DynamicGrid.astro";
import MainLayout from "../layouts/MainLayout.astro";

const items3 = [
  {
    title: "Built From Scratch",
    body: "Custom websites without relying on cookie-cutter templates.",
  },
  {
    title: "Fast Enough to Keep People Around",
    body: "Pages that load quickly and feel smooth to use.",
  },
  {
    title: "Designed for Real People",
    body: "Clear layouts that help visitors understand what to do next.",
  },
];

const items4 = [
  { title: "Step One", body: "Intro and planning." },
  { title: "Step Two", body: "Design direction." },
  { title: "Step Three", body: "Build and refine." },
  { title: "Step Four", body: "Launch and support." },
];

const items6 = [
  { title: "One", body: "Text" },
  { title: "Two", body: "Text" },
  { title: "Three", body: "Text" },
  { title: "Four", body: "Text" },
  { title: "Five", body: "Text" },
  { title: "Six", body: "Text" },
];
---

<MainLayout>
  <DynamicGrid items={items3} columns={3} />
  <DynamicGrid items={items4} columns={4} />
  <DynamicGrid items={items6} minWidth={240} />
  <DynamicGrid
    items={items6}
    columns={3}
    cardClassName="bg-[#1d7c84] text-[#f3ecd9] px-4 py-4 min-h-[190px]"
    className="max-w-6xl"
  />
</MainLayout>
